      renderProseSection("How work flows through", pl.flow),
      renderPersonaTable(pl.personas),
      `<section class="detail-section"><h3>Drill into phases</h3><ul>${pl.phases.map((n) => `<li><button type="button" class="detail-back" data-jump="${n}" style="font:inherit;cursor:pointer;background:none;border:none;color:#2563eb;padding:0">Phase ${n} — ${PHASES[n]?.name}</button></li>`).join("")}</ul></section>`
    ].join("");
    bodyEl.querySelectorAll("[data-jump]").forEach((btn) => {
      btn.addEventListener("click", () => pushView({ type: "phase", id: +btn.dataset.jump, label: `Phase ${btn.dataset.jump}` }));
    });
  }

  function renderInfra(key) {
    const i = INFRA[key];
    if (!i) return;
    hideTabs();
    titleEl.textContent = i.title;
    subtitleEl.textContent = i.desc;
    badgesEl.innerHTML = i.fti ? `<span class="detail-badge">FTI-${i.fti}</span>` : `<span class="detail-badge">Delivery</span>`;
    bodyEl.innerHTML = `<section class="detail-section"><h3>${renderRoleIcons(parseRoles(i.roles || ""), "sm")} Scope</h3><p>${i.desc}</p></section>`;
  }

  function isDapsFieldFilled(key, draft) {
    draft = draft || dapsDraft;
    const meta = DAPS_FIELDS[key];
    if (!meta) return false;
    if (meta.type === "predictors") {
      return (draft.predictors || []).some((p) => String(p).trim());
    }
    if (meta.type === "relationship") {
      return Boolean(String(draft.relationshipType || "").trim());
    }
    return Boolean(String(draft.fields?.[key] || "").trim());
  }

  function updateDapsBlockIndicators() {
    document.querySelectorAll("[data-daps-field]").forEach((el) => {
      const key = el.dataset.dapsField;
      el.classList.toggle("daps-block--filled", isDapsFieldFilled(key));
    });
  }

  function collectDapsFormFromDOM() {
    const form = bodyEl.querySelector(".daps-intake-form");
    if (!form) return;
    dapsDraft.projectName = form.querySelector("#dapsProjectName")?.value || "";
    Object.keys(DAPS_FIELDS).forEach((key) => {
      const meta = DAPS_FIELDS[key];
      if (meta.type === "predictors") {
        dapsDraft.predictors = [...form.querySelectorAll("[data-predictor-input]")].map((el) => el.value);
      } else if (meta.type === "relationship") {
        const checked = form.querySelector('input[name="relationshipType"]:checked');
        dapsDraft.relationshipType = checked ? checked.value : "";
      } else {
        const el = form.querySelector(`[data-daps-input="${key}"]`);
        if (el) dapsDraft.fields[key] = el.value;
      }
    });
  }

  function saveDapsDraft(options) {
    options = options || {};
    collectDapsFormFromDOM();
    if (options.requireProjectName && !dapsDraft.projectName.trim()) {
      const input = bodyEl.querySelector("#dapsProjectName");
      input?.classList.add("is-invalid");
      input?.focus();
      setDapsSaveHint("Enter a project name to save this draft.", true);
      return false;
    }
    bodyEl.querySelector("#dapsProjectName")?.classList.remove("is-invalid");
    dapsDraft.updatedAt = new Date().toISOString();
    const key = dapsStorageKey(dapsDraft.projectName);
    try {
      localStorage.setItem(key, JSON.stringify(dapsDraft));
      if (key !== DAPS_DEFAULT_KEY) {
        localStorage.setItem(DAPS_DEFAULT_KEY, JSON.stringify(dapsDraft));
      }
    } catch (err) {
      setDapsSaveHint("Could not save — storage may be full.", true);
      return false;
    }
    updateDapsBlockIndicators();
    const hint = options.manual
      ? `Saved to ${key}${dapsDraft.projectName.trim() ? ` (${dapsDraft.projectName.trim()})` : ""}.`
      : "Draft saved automatically.";
    setDapsSaveHint(hint, false);
    return true;
  }

  function scheduleDapsAutoSave() {
    clearTimeout(dapsSaveTimer);
    dapsSaveTimer = setTimeout(() => saveDapsDraft({ manual: false }), 600);
  }

  function setDapsSaveHint(message, isError) {
    const hint = bodyEl.querySelector("#dapsSaveHint");
    if (hint) {
      hint.textContent = message;
      hint.style.color = isError ? "#b91c1c" : "";
    }
  }

  function clearDapsDraft() {
    if (!window.confirm("Clear the DAPS intake draft from this browser?")) return;
    dapsDraft = createEmptyDapsDraft();
    try {
      localStorage.removeItem(DAPS_DEFAULT_KEY);
    } catch (_) { /* ignore */ }
    updateDapsBlockIndicators();
    const view = stack[stack.length - 1];
    if (view?.type === "daps" && view.mode !== "view") {
      renderDaps(view);
    }
  }

  function buildDapsExportPack() {
    collectDapsFormFromDOM();
    return {
      schema: "daps-intake-pack-v1",
      projectName: dapsDraft.projectName.trim() || null,
      exportedAt: new Date().toISOString(),
      source: "ml-lifecycle-e2e-poster",
      updatedAt: dapsDraft.updatedAt,
      businessValue: {
        organizationKpi: dapsDraft.fields.organizationKpi || "",
        operationalKpis: dapsDraft.fields.operationalKpis || "",
        projectKpi: dapsDraft.fields.projectKpi || ""
      },
      decisionFramework: {
        decisionsActions: dapsDraft.fields.decisionsActions || "",
        decisionAgent: dapsDraft.fields.decisionAgent || "",
        decisionTiming: dapsDraft.fields.decisionTiming || "",
        unitOfAnalysis: dapsDraft.fields.unitOfAnalysis || "",
        interventionScope: dapsDraft.fields.interventionScope || ""
      },
      dataAnalyticProblem: {
        targetVariables: dapsDraft.fields.targetVariables || "",
        predictors: (dapsDraft.predictors || []).filter((p) => String(p).trim()),
        relationshipType: dapsDraft.relationshipType || ""
      }
    };
  }

  function exportDapsJson() {
    if (!saveDapsDraft({ manual: true, requireProjectName: true })) return;
    const pack = buildDapsExportPack();
    const slug = slugifyProjectName(dapsDraft.projectName);
    const blob = new Blob([JSON.stringify(pack, null, 2)], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = `daps-intake-${slug}.json`;
    a.click();
    URL.revokeObjectURL(url);
    setDapsSaveHint(`Exported ${a.download}.`, false);
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function renderDapsFieldGroup(key, focusField) {
    const meta = DAPS_FIELDS[key];
    if (!meta) return "";
    const focusClass = focusField === key ? " daps-form-group--focus" : "";
    if (meta.type === "predictors") {
      const rows = (dapsDraft.predictors || ["", "", ""]).map((val, idx) => `
        <div class="daps-predictor-row" data-predictor-row="${idx}">
          <input type="text" class="daps-form-input" data-predictor-input data-predictor-index="${idx}" placeholder="${escapeHtml(meta.placeholder)} (X${idx + 1})" value="${escapeHtml(val)}" />
          <button type="button" class="daps-predictor-remove" data-predictor-remove="${idx}" aria-label="Remove predictor ${idx + 1}" title="Remove">×</button>
        </div>`).join("");
      return `
        <div class="daps-form-group${focusClass}" id="daps-field-${key}" data-daps-field-group="${key}">
          <label class="daps-form-label">${meta.label}</label>
          <p class="daps-form-hint">${meta.placeholder}</p>
          <div id="dapsPredictorList">${rows}</div>
          <button type="button" class="daps-btn" id="dapsAddPredictor">+ Add predictor</button>
        </div>`;
    }
    if (meta.type === "relationship") {
      const options = DAPS_RELATIONSHIP_OPTIONS.map((opt) => `
        <label class="daps-rel-option">
          <input type="radio" name="relationshipType" value="${opt.value}" ${dapsDraft.relationshipType === opt.value ? "checked" : ""} />
          ${opt.label}
        </label>`).join("");
      return `
        <div class="daps-form-group${focusClass}" id="daps-field-${key}" data-daps-field-group="${key}">
          <span class="daps-form-label">${meta.label}</span>
          <p class="daps-form-hint">${meta.placeholder}</p>
          <div class="daps-rel-options">${options}</div>
        </div>`;
    }
    const value = escapeHtml(dapsDraft.fields[key] || "");
    const inputTag = meta.multiline
      ? `<textarea class="daps-form-textarea" data-daps-input="${key}" placeholder="${escapeHtml(meta.placeholder)}" rows="3">${value}</textarea>`
      : `<input type="text" class="daps-form-input" data-daps-input="${key}" placeholder="${escapeHtml(meta.placeholder)}" value="${value}" />`;
    return `
      <div class="daps-form-group${focusClass}" id="daps-field-${key}" data-daps-field-group="${key}">
        <label class="daps-form-label" for="daps-input-${key}">${meta.label}</label>
        <p class="daps-form-hint">${meta.placeholder}</p>
        ${inputTag.replace(`data-daps-input="${key}"`, `id="daps-input-${key}" data-daps-input="${key}"`)}
      </div>`;
  }

  function renderDapsFormHTML(focusField) {
    const tiersHtml = DAPS_TIERS.map((tier) => {
      const fields = Object.entries(DAPS_FIELDS).filter(([, meta]) => meta.tier === tier.key).map(([key]) => renderDapsFieldGroup(key, focusField)).join("");
      return `
        <section class="daps-form-tier ${tier.tierClass}">
          <div class="daps-form-tier-head">${tier.title}</div>
          <div class="daps-form-tier-body">${fields}</div>
        </section>`;
    }).join("");

    return `
      <form class="daps-intake-form" id="dapsIntakeForm" novalidate>
        <div class="daps-form-toolbar">
          <label for="dapsProjectName">Project name</label>
          <input type="text" class="daps-form-project" id="dapsProjectName" placeholder="e.g. churn-prediction-q3" value="${escapeHtml(dapsDraft.projectName || "")}" required />
          <div class="daps-form-actions">
            <button type="button" class="daps-btn daps-btn--primary" id="dapsSaveBtn">Save draft</button>
            <button type="button" class="daps-btn" id="dapsExportBtn">Export JSON</button>
            <button type="button" class="daps-btn daps-btn--danger" id="dapsClearBtn">Clear draft</button>
          </div>
          <p class="daps-save-hint" id="dapsSaveHint">Drafts persist in this browser via localStorage.</p>
        </div>
        ${tiersHtml}
      </form>`;
  }

  function bindDapsFormEvents(focusField) {
    const form = bodyEl.querySelector(".daps-intake-form");
    if (!form) return;

    form.querySelector("#dapsSaveBtn")?.addEventListener("click", () => saveDapsDraft({ manual: true, requireProjectName: true }));
    form.querySelector("#dapsExportBtn")?.addEventListener("click", exportDapsJson);
    form.querySelector("#dapsClearBtn")?.addEventListener("click", clearDapsDraft);

    form.querySelectorAll("[data-daps-input], [data-predictor-input], #dapsProjectName").forEach((el) => {
      el.addEventListener("input", scheduleDapsAutoSave);
    });
    form.querySelectorAll('input[name="relationshipType"]').forEach((el) => {
      el.addEventListener("change", scheduleDapsAutoSave);
    });

    form.querySelector("#dapsAddPredictor")?.addEventListener("click", () => {
      collectDapsFormFromDOM();
      dapsDraft.predictors.push("");
      const view = stack[stack.length - 1];
      renderDaps({ ...view, mode: "form" });
    });

    form.querySelectorAll("[data-predictor-remove]").forEach((btn) => {
      btn.addEventListener("click", () => {
        collectDapsFormFromDOM();
        const idx = +btn.dataset.predictorRemove;
        if (dapsDraft.predictors.length <= 1) {
          dapsDraft.predictors = [""];
        } else {
          dapsDraft.predictors.splice(idx, 1);
        }
        const view = stack[stack.length - 1];
        renderDaps({ ...view, mode: "form" });
      });
    });

    if (focusField) {
      const target = bodyEl.querySelector(`#daps-field-${focusField}`);
      if (target) {
        requestAnimationFrame(() => {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
          target.querySelector("input, textarea, select")?.focus();
        });
      }
    }
  }

  function setDapsTabs(activeMode, view) {
    if (!tabsEl) return;
    tabsEl.hidden = false;
    tabsEl.innerHTML = `
      <button type="button" class="panel-tab${activeMode === "form" ? " panel-tab--active" : ""}" data-daps-tab="form" role="tab" aria-selected="${activeMode === "form"}">Fill in</button>
      <button type="button" class="panel-tab panel-tab--view${activeMode === "view" ? " panel-tab--active" : ""}" data-daps-tab="view" role="tab" aria-selected="${activeMode === "view"}">View</button>`;
    tabsEl.querySelectorAll("[data-daps-tab]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const newMode = btn.dataset.dapsTab;
        const current = stack[stack.length - 1];
        if (current?.type === "daps" && current.mode !== newMode) {
          current.mode = newMode;
          renderDaps(current);
        }
      });
    });
  }

  function renderDaps(view) {
    const fieldKey = view.field;
    const fieldMeta = fieldKey ? DAPS_FIELDS[fieldKey] : null;
    const phase = view.phase ?? fieldMeta?.phase ?? 1;
    const mode = view.mode || "form";

    titleEl.textContent = fieldMeta ? `DAPS · ${fieldMeta.label}` : "DAPS intake workbook";
    subtitleEl.textContent = "de Mast & Lokkerbol (2024) — templatized intake blocks";
    badgesEl.innerHTML = [
      `<span class="detail-badge">Phase ${phase}</span>`,
      `<span class="detail-badge">DAPS</span>`,
      `<span class="detail-badge detail-badge--gov">Intake</span>`
    ].join("");
    setDapsTabs(mode, view);

    if (mode === "view") {
      subtitleEl.textContent = `Phase ${phase} matrix detail · ${PHASES[phase]?.name || ""}`;
      bodyEl.innerHTML = getPhaseBodyHTML(phase);
      return;
    }

    bodyEl.innerHTML = renderDapsFormHTML(fieldKey);
    bindDapsFormEvents(fieldKey);
  }

  function renderGap() {
    hideTabs();
    titleEl.textContent = "FTI build → delivery gap";
    subtitleEl.textContent = "Between phase 8 (I artifact) and phase 9 (production delivery)";
    badgesEl.innerHTML = "";
    bodyEl.innerHTML = [
      renderSection("Handover", [
        "FTI build complete: inference pipeline artifact, application card (inference), gateway config draft",
        "Delivery lane chooses mode: batch (trigger FTI pipeline, AZML batch endpoint, schedule) vs realtime (API, model embedded, online feature store, gateway enforce)",
        "DS experiments → MLE production pipelines still applies within training→inference handoff (7→8)",
        "Research notebooks → reproducible inference pipeline code before production trigger"
      ]),
      `<section class="detail-section"><h3>Related phases</h3><ul>
        <li><button type="button" class="detail-back" data-jump="8" style="font:inherit;cursor:pointer;background:none;border:none;color:#2563eb;padding:0">Phase 8 — Inference (I) · FTI build</button></li>
        <li><button type="button" class="detail-back" data-jump="9" style="font:inherit;cursor:pointer;background:none;border:none;color:#2563eb;padding:0">Phase 9 — Production deploy · delivery modes</button></li>
      </ul></section>`
    ].join("");
    bodyEl.querySelectorAll("[data-jump]").forEach((btn) => {
      btn.addEventListener("click", () => pushView({ type: "phase", id: +btn.dataset.jump, label: `Phase ${btn.dataset.jump}` }));
    });
  }

  function applyView(view) {
    if (view.type !== "pillar") setActivePillar(null);
    switch (view.type) {
      case "phase": renderPhase(view.id); break;
      case "daps": renderDaps(view); break;
      case "monitor": renderMonitor(view.id); break;
      case "gov": renderGov(view.id); break;
      case "pillar": renderPillar(view.id); break;
      case "infra": renderInfra(view.id); break;
      case "gap": renderGap(); break;
      default: break;
    }
    breadcrumb.textContent = ["Poster", ...stack.map((s) => s.label)].join(" › ");
    backBtn.disabled = stack.length <= 1;
  }

  function pushView(view) {
    stack.push(view);
    applyView(view);
    openPanel();
  }

  function popView() {
    if (stack.length <= 1) return;
    stack.pop();
    applyView(stack[stack.length - 1]);
  }

  function openPanel() {
    isOpen = true;
    document.body.classList.add("panel-open");
    backdrop.classList.add("is-open");
    panel.classList.add("is-open");
    backdrop.setAttribute("aria-hidden", "false");
    panel.setAttribute("aria-hidden", "false");
  }

  function closePanel() {
    isOpen = false;
    document.body.classList.remove("panel-open");
    backdrop.classList.remove("is-open");
    panel.classList.remove("is-open");
    backdrop.setAttribute("aria-hidden", "true");
    panel.setAttribute("aria-hidden", "true");
    stack.length = 0;
    setActivePillar(null);
  }

  function openPhase(n, label) {
    pushView({ type: "phase", id: n, label: label || `Phase ${n}` });
  }

  document.querySelectorAll("[data-phase]").forEach((el) => {
    bindInteractive(el, () => openPhase(+el.dataset.phase, `Phase ${el.dataset.phase}`));
  });

  document.querySelectorAll("[data-daps]").forEach((el) => {
    bindInteractive(el, () => {
      const field = el.dataset.dapsField;
      const phase = +el.dataset.daps;
      const label = el.dataset.dapsLabel || "DAPS";
      pushView({
        type: "daps",
        field,
        phase,
        mode: "form",
        label: `DAPS · ${label}`
      });
    });
  });

  updateDapsBlockIndicators();
  hydratePosterRoles();
  initSwimlanes();

  document.querySelectorAll("[data-monitor]").forEach((el) => {
    bindInteractive(el, () => pushView({ type: "monitor", id: el.dataset.monitor, label: MONITORING[el.dataset.monitor]?.title || "Monitoring" }));
  });

  document.querySelectorAll("[data-gov]").forEach((el) => {
    bindInteractive(el, () => pushView({ type: "gov", id: el.dataset.gov, label: "Governance" }));
  });

  document.querySelectorAll("[data-pillar-detail]").forEach((el) => {
    bindInteractive(el, () => pushView({ type: "pillar", id: el.dataset.pillarDetail, label: PILLARS[el.dataset.pillarDetail]?.title || "Pillar" }));
  });

  document.querySelectorAll("[data-infra]").forEach((el) => {
    bindInteractive(el, () => pushView({ type: "infra", id: el.dataset.infra, label: INFRA[el.dataset.infra]?.title || "Pipeline" }));
  });

  const gapEl = document.querySelector("[data-gap]");
  if (gapEl) {
    bindInteractive(gapEl, () => pushView({ type: "gap", id: "handover", label: "FTI build → delivery gap" }));
  }

  backBtn.addEventListener("click", popView);
  closeBtn.addEventListener("click", closePanel);
  backdrop.addEventListener("click", closePanel);
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    if (seqOverlay?.classList.contains("is-open")) {
      closeSequenceFlow();
      return;
    }
    if (isOpen) closePanel();
    else if (focusedLaneKey || laneKeyboardKey) clearLaneFocus();
  });

  const SEQ_MAT_CLASS = {
    0: "intake", 1: "intake", 2: "intake",
    3: "poc", 4: "poc", 5: "poc",
    6: "proto",
    7: "pilot", 8: "pilot",
    9: "prd",
    10: "prod",
    11: "op",
    12: "ret"
  };

  const SEQ_SHORT = {
    0: "Envision", 1: "DAPS", 2: "KPI/SLA", 3: "Feasibility", 4: "Architecture",
    5: "EDA", 6: "Feature F", 7: "Training T", 8: "Inference I", 9: "PRD deploy",
    10: "Integrated", 11: "Monitor", 12: "Retire"
  };

  const seqOverlay = document.getElementById("seqOverlay");
  const seqOpenBtn = document.getElementById("openSequenceBtn");
  const seqCloseBtn = document.getElementById("seqClose");
  const seqSpine = document.getElementById("seqSpine");

  function closeSequenceFlow() {
    if (!seqOverlay) return;
    seqOverlay.classList.remove("is-open");
    seqOverlay.setAttribute("aria-hidden", "true");
    if (!isOpen) document.body.classList.remove("panel-open");
  }

  function openSequenceFlow() {
    if (!seqOverlay) return;
    seqOverlay.classList.add("is-open");
    seqOverlay.setAttribute("aria-hidden", "false");
    document.body.classList.add("panel-open");
    seqCloseBtn?.focus();
  }

  function initSequenceFlow() {
    if (!seqSpine) return;
    seqSpine.innerHTML = "";
    for (let n = 0; n <= 12; n++) {
      if (n > 0) {
        const arr = document.createElement("span");
        arr.className = "seq-arrow";
        arr.textContent = "→";
        arr.setAttribute("aria-hidden", "true");
        seqSpine.appendChild(arr);
      }
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = `seq-phase seq-phase--${SEQ_MAT_CLASS[n]}`;
      btn.title = PHASES[n]?.name ? `Phase ${n}: ${PHASES[n].name}` : `Phase ${n}`;
      btn.innerHTML =
        `<span class="seq-phase-node">${n}</span>` +
        `<span class="seq-phase-label">${SEQ_SHORT[n] || PHASES[n]?.name || ""}</span>`;
      btn.addEventListener("click", () => {
        closeSequenceFlow();
        openPhase(n, `Phase ${n}`);
      });
      seqSpine.appendChild(btn);
    }
    seqOpenBtn?.addEventListener("click", openSequenceFlow);
    seqCloseBtn?.addEventListener("click", closeSequenceFlow);
    seqOverlay?.addEventListener("click", (e) => {
      if (e.target === seqOverlay) closeSequenceFlow();
    });
  }

  initSequenceFlow();

  const POSTER_HELP_KEY = "ml-lifecycle-poster-help-dismissed";
  const posterHelpBanner = document.getElementById("posterHelpBanner");
  const posterHelpFab = document.getElementById("posterHelpFab");
  const posterHelpDismiss = document.getElementById("posterHelpDismiss");
  const posterHelpToggleHero = document.getElementById("posterHelpToggleHero");

  function isPosterHelpVisible() {
    return posterHelpBanner && !posterHelpBanner.hidden;
  }

  function setPosterHelpVisible(show) {
    if (!posterHelpBanner) return;
    posterHelpBanner.hidden = !show;
    const expanded = Boolean(show);
    posterHelpFab?.setAttribute("aria-expanded", expanded ? "true" : "false");
    posterHelpToggleHero?.setAttribute("aria-expanded", expanded ? "true" : "false");
  }

  function togglePosterHelp() {
    setPosterHelpVisible(!isPosterHelpVisible());
  }

  function dismissPosterHelp() {
    try {
      localStorage.setItem(POSTER_HELP_KEY, "1");
    } catch (_) { /* ignore */ }
    setPosterHelpVisible(false);
  }

  posterHelpFab?.addEventListener("click", togglePosterHelp);
  posterHelpToggleHero?.addEventListener("click", togglePosterHelp);
  posterHelpDismiss?.addEventListener("click", dismissPosterHelp);

  try {
    if (localStorage.getItem(POSTER_HELP_KEY) !== "1") setPosterHelpVisible(true);
  } catch (_) {
    setPosterHelpVisible(true);
  }
})();
  </script>
</body>
</html>
