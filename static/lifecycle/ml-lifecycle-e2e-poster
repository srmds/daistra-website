  function initSwimlanes() {
    const phases = document.querySelector(".phases");
    const hoverMedia = window.matchMedia("(hover: hover) and (min-width: 900px)");
    let hoverExpandTimer = null;

    function applyKeyboardLaneExpand(key) {
      if (!hoverMedia.matches || !phases || !key) return;
      const pillar = phases.querySelector(`.pillar[data-pillar="${key}"]`);
      if (!pillar) return;
      phases.querySelectorAll(".pillar.is-hover").forEach((el) => {
        if (el !== pillar) el.classList.remove("is-hover");
      });
      pillar.classList.add("is-hover");
    }

    function focusLaneByKey(key) {
      if (!PILLAR_KEYS.includes(key)) return;
      setLaneKeyboardFocus(key);
      if (focusedLaneKey) setLaneFocus(key);
      applyKeyboardLaneExpand(key);
      const pillar = phases?.querySelector(`.pillar[data-pillar="${key}"]`);
      pillar?.focus({ preventScroll: false });
    }

    function navigateLane(delta) {
      const base = focusedLaneKey || laneKeyboardKey || PILLAR_KEYS[0];
      let idx = PILLAR_KEYS.indexOf(base);
      if (idx < 0) idx = 0;
      idx = (idx + delta + PILLAR_KEYS.length) % PILLAR_KEYS.length;
      focusLaneByKey(PILLAR_KEYS[idx]);
    }

    document.addEventListener("keydown", (e) => {
      if (!shouldHandleLaneKeys(e)) return;
      if (e.key === "ArrowLeft") {
        e.preventDefault();
        navigateLane(-1);
        return;
      }
      if (e.key === "ArrowRight") {
        e.preventDefault();
        navigateLane(1);
        return;
      }
      const digit = e.key >= "1" && e.key <= "5" ? Number(e.key) - 1 : -1;
      if (digit >= 0) {
        e.preventDefault();
        focusLaneByKey(PILLAR_KEYS[digit]);
      }
    });

    function clearHoverState() {
      if (hoverExpandTimer) {
        clearTimeout(hoverExpandTimer);
        hoverExpandTimer = null;
      }
      phases?.querySelectorAll(".pillar.is-hover").forEach((pillar) => {
        pillar.classList.remove("is-hover");
      });
    }

    function setHoverPillar(pillar) {
      if (!hoverMedia.matches || !phases) return;
      if (hoverExpandTimer) {
        clearTimeout(hoverExpandTimer);
        hoverExpandTimer = null;
      }
      phases.querySelectorAll(".pillar.is-hover").forEach((el) => {
        if (el !== pillar) el.classList.remove("is-hover");
      });
      hoverExpandTimer = window.setTimeout(() => {
        pillar.classList.add("is-hover");
        hoverExpandTimer = null;
      }, 200);
    }

    if (phases && hoverMedia.matches) {
      phases.querySelectorAll(".pillar[data-pillar]").forEach((pillar) => {
        pillar.addEventListener("mouseenter", () => setHoverPillar(pillar));
        pillar.addEventListener("mouseleave", (e) => {
          const related = e.relatedTarget;
          if (!related || !phases.contains(related)) {
            clearHoverState();
            return;
          }
          if (!related.closest?.(".pillar[data-pillar]")) clearHoverState();
        });
      });

      phases.addEventListener("mouseleave", (e) => {
        if (!phases.contains(e.relatedTarget)) clearHoverState();
      });
    }

    document.querySelectorAll(".phases .pillar[data-pillar]").forEach((pillar) => {
      const key = pillar.dataset.pillar;
      const pl = PILLARS[key];
      const head = pillar.querySelector(".chevron-head");

      const phaseNums = pl?.phases || [];
      const rangeLabel = lanePhaseRangeLabel(phaseNums);
      const rangeShort = lanePhaseRangeShort(phaseNums);

      if (head && head.dataset.pillarDetail) {
        const numEl = head.querySelector(".chevron-num");
        const titleEl = head.querySelector(".chevron-head__title");
        const num = numEl ? numEl.textContent.trim() : "";
        let titleText = titleEl ? titleEl.textContent.trim() : head.textContent.trim();
        const legacy = titleText.match(/^([①②③④⑤])\s*(.+)$/);
        if (legacy) titleText = legacy[2].trim();
        const numHtml = num ? `<span class="chevron-num">${num}</span>` : "";
        const rangeHtml = rangeShort
          ? `<span class="chevron-head__range" title="${rangeLabel}">${rangeShort}</span>`
          : "";
        head.removeAttribute("data-pillar-detail");
        head.removeAttribute("tabindex");
        head.innerHTML =
          numHtml +
          `<span class="chevron-head__text"><span class="chevron-head__title-row"><span class="chevron-head__title">${titleText}</span>${rangeHtml}</span></span>` +
          `<button type="button" class="chevron-brief clickable" data-pillar-detail="${key}" tabindex="0" aria-label="Open lane briefing for ${titleText}">↗</button>`;
      }

      pillar.querySelectorAll(".lane__peek").forEach((el) => el.remove());

      pillar.setAttribute("role", "region");
      pillar.setAttribute("aria-label", pl?.title || key);
      pillar.setAttribute("aria-expanded", "false");
      pillar.setAttribute("tabindex", "0");

      pillar.addEventListener("click", (e) => {
        if (e.target.closest(".clickable, [data-phase], [data-daps], [data-gov], [data-monitor], [data-infra], [data-gap], [data-flow-roles], [data-deploy-roles], .chevron-brief")) return;
        toggleLaneFocus(key);
      });

      pillar.addEventListener("keydown", (e) => {
        if (e.target !== pillar && !e.target.classList.contains("chevron-head__title")) return;
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          toggleLaneFocus(key);
        }
      });

      head?.addEventListener("click", (e) => {
        if (e.target.closest(".chevron-brief")) return;
        e.stopPropagation();
        toggleLaneFocus(key);
      });
    });

    document.addEventListener("click", (e) => {
      if (focusedLaneKey && !e.target.closest(".phases")) clearLaneFocus();
    });
  }

