<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Daistra | ML Project Lifecycle</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --ink: #070d18;
      --muted: #475569;
      --line: #0f172a;
      --box-line: #64748b;
      --grid: #d8dee9;
      --white: #ffffff;
      --discover: #fffbeb;
      --discover-head: #fbbf24;
      --plan: #eff6ff;
      --plan-head: #60a5fa;
      --model: #eef2ff;
      --model-head: #818cf8;
      --deploy: #fff7ed;
      --deploy-head: #fb923c;
      --operate: #ecfdf5;
      --operate-head: #34d399;
      --gov: #ede9fe;
      --gov-h: #6d28d9;
      --gap: #fecaca;
      --gap-h: #b91c1c;
      --steward: #bae6fd;
      --steward-h: #0369a1;
      --click-shadow: 0 3px 10px rgba(15, 23, 42, 0.12);
      --lane-shadow: 0 2px 4px rgba(0, 0, 0, 0.06), 0 6px 18px rgba(15, 23, 42, 0.1);
      --space-1: 8px;
      --space-2: 16px;
      --radius-sm: 8px;
      --radius-md: 10px;
      --radius-lg: 12px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "DM Sans", system-ui, sans-serif;
      background:
        repeating-linear-gradient(0deg, var(--grid) 0, var(--grid) 1px, transparent 1px, transparent 20px),
        repeating-linear-gradient(90deg, var(--grid) 0, var(--grid) 1px, transparent 1px, transparent 20px),
        #e8edf4;
      color: var(--ink);
      line-height: 1.4;
      padding: 8px 4px;
    }
    body.panel-open { overflow: hidden; }
    @media print {
      body { background: white; padding: 0; overflow: visible; }
      .poster { box-shadow: none !important; max-width: none !important; }
      .detail-panel, .detail-backdrop, .seq-overlay, .poster-help-banner, .poster-help-fab { display: none !important; }
      .clickable { cursor: default !important; }
      .phases { flex-direction: row; padding: 0; }
      .pillar { margin-left: 0; flex: 1 1 0; box-shadow: none; transform: none; }
    }
    .poster {
      max-width: min(2560px, 99.5vw);
      margin: 0 auto;
      background: var(--white);
      border: 2.5px solid var(--line);
      border-radius: 14px;
      box-shadow: 0 24px 64px rgba(15, 23, 42, 0.12);
      overflow: hidden;
    }
    .hero {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 20px 28px;
      padding: 20px 24px 16px;
      border-bottom: 2.5px solid var(--line);
      background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
      color: white;
      text-align: left;
    }
    .hero-brand {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      padding-top: 2px;
    }
    .hero-logo {
      display: block;
      margin: 0;
      height: 72px;
      width: auto;
      max-width: 180px;
      object-fit: contain;
      object-position: left center;
    }
    .hero-content {
      flex: 1;
      min-width: 0;
    }
    @media (max-width: 540px) {
      .hero {
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 14px;
      }
      .hero-brand { padding-top: 0; }
      .hero-logo { height: 56px; max-width: min(240px, 70vw); }
      .hero .meta,
      .hero-actions { justify-content: center; }
    }
    .hero h1 {
      font-size: clamp(1.85rem, 3.4vw, 2.65rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.15;
    }
    .hero-brand { font-weight: 800; }
    .hero-sep {
      margin: 0 0.2em;
      font-weight: 500;
      opacity: 0.55;
      letter-spacing: 0.02em;
    }
    .hero-subject { font-weight: 700; }
    .hero .tagline {
      margin-top: 6px;
      font-size: 0.82rem;
      font-weight: 500;
      opacity: 0.72;
      letter-spacing: 0.01em;
    }
    .hero .meta { margin-top: 10px; display: flex; flex-wrap: wrap; justify-content: flex-start; gap: 6px; }
    .hero .pill {
      font-size: 0.62rem; font-weight: 600; padding: 3px 10px; border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.22); background: rgba(255,255,255,0.06);
      text-transform: uppercase; letter-spacing: 0.05em;
      opacity: 0.85;
    }
    .hero-actions {
      margin-top: 14px;
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: 10px;
    }
    .hero-seq-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 10px;
      border: 2px solid rgba(255, 255, 255, 0.45);
      background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0.08) 100%);
      color: white;
      font-family: inherit;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
    }
    .hero-seq-btn:hover {
      background: linear-gradient(135deg, rgba(255,255,255,0.28) 0%, rgba(255,255,255,0.12) 100%);
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.28);
    }
    .hero-seq-btn:focus-visible {
      outline: 2px solid #93c5fd;
      outline-offset: 3px;
    }
    a.hero-link-btn {
      text-decoration: none;
      color: inherit;
    }
    .hero-seq-btn__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.5rem;
      height: 1.5rem;
      border-radius: 6px;
      background: rgba(255, 255, 255, 0.2);
      font-size: 0.95rem;
    }
    .hero-help-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.35);
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.95);
      font-family: inherit;
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }
    .hero-help-btn:hover { background: rgba(255, 255, 255, 0.16); }
    .hero-help-btn:focus-visible { outline: 2px solid #93c5fd; outline-offset: 3px; }

    .poster-help-banner {
      border-bottom: 1px solid #e2e8f0;
      background: #f8fafc;
      color: #1e293b;
    }
    .poster-help-banner[hidden] { display: none !important; }
    .poster-help-banner__inner {
      max-width: none;
      margin: 0 auto;
      padding: 10px 16px;
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px 14px;
      align-items: start;
    }
    .poster-help-banner__icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      border-radius: 10px;
      background: #ffffff;
      border: 1.5px solid #cbd5e1;
      color: #475569;
      font-size: 1rem;
      font-weight: 800;
      line-height: 1;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .poster-help-banner__content {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .poster-help-banner__title {
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #0f172a;
    }
    .poster-help-banner__model {
      margin: 0;
      padding: 6px 10px;
      border-radius: var(--radius-sm);
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-left: 3px solid #3b82f6;
      font-size: 0.82rem;
      line-height: 1.45;
      color: #334155;
    }
    .poster-help-banner__model strong { font-weight: 700; color: #1e40af; }
    .poster-help-banner__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 4px 16px;
      font-size: 0.8rem;
      line-height: 1.4;
      color: #475569;
    }
    .poster-help-banner__list li {
      display: flex;
      gap: 6px;
      align-items: baseline;
    }
    .poster-help-banner__list kbd {
      flex-shrink: 0;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.68rem;
      font-weight: 600;
      padding: 1px 5px;
      border-radius: 4px;
      border: 1px solid #cbd5e1;
      background: #f1f5f9;
      color: #334155;
    }
    .poster-help-banner__list strong { color: #0f172a; font-weight: 600; }
    .poster-help-banner__actions {
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: flex-end;
      align-self: center;
    }
    .poster-help-banner__dismiss {
      padding: 7px 14px;
      border-radius: 8px;
      border: 1px solid #cbd5e1;
      background: #ffffff;
      color: #334155;
      font-family: inherit;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }
    .poster-help-banner__dismiss:hover { background: #f1f5f9; border-color: #94a3b8; }
    .poster-help-fab {
      position: fixed;
      right: 18px;
      bottom: 18px;
      z-index: 120;
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 999px;
      border: 2px solid #3b82f6;
      background: #ffffff;
      color: #1d4ed8;
      font-family: inherit;
      font-size: 1.1rem;
      font-weight: 800;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(37, 99, 235, 0.25);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .poster-help-fab:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35);
    }
    .poster-help-fab:focus-visible { outline: 2px solid #2563eb; outline-offset: 3px; }
    .poster-help-fab[aria-expanded="true"] {
      background: #2563eb;
      color: #ffffff;
      border-color: #1d4ed8;
    }
    @media (max-width: 720px) {
      .poster-help-banner__inner {
        grid-template-columns: auto 1fr;
      }
      .poster-help-banner__actions {
        grid-column: 1 / -1;
        flex-direction: row;
        justify-content: flex-end;
        align-self: auto;
      }
    }

    /* Poster zones — top→bottom mental model */
    .poster-zone__label {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px var(--space-2);
      font-size: 0.84rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: #334155;
      background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
    }
    .poster-zone__step {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.35rem;
      height: 1.35rem;
      border-radius: 6px;
      background: #e2e8f0;
      color: #334155;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.7rem;
      font-weight: 700;
      flex-shrink: 0;
    }
    .poster-zone--when { border-bottom: 2px solid var(--line); }
    .poster-zone--when .lifecycle-stages__head { border-bottom: none; }
    .poster-zone__label--lanes {
      border-bottom: 1px solid #e2e8f0;
      margin: 0;
    }
    .poster-zone--who .personas-title {
      border-bottom: none;
      padding-top: var(--space-1);
      padding-bottom: var(--space-1);
    }

    /* Sequence flow mental model overlay */
    .seq-overlay {
      position: fixed;
      inset: 0;
      z-index: 2000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: rgba(7, 13, 24, 0.72);
      backdrop-filter: blur(6px);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.25s ease, visibility 0.25s;
    }
    .seq-overlay.is-open {
      opacity: 1;
      visibility: visible;
    }
    .seq-dialog {
      width: min(1180px, 98vw);
      max-height: min(92vh, 900px);
      overflow: auto;
      background: #ffffff;
      border-radius: 16px;
      border: 2.5px solid var(--line);
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
    }
    .seq-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding: 20px 24px 16px;
      border-bottom: 2px solid var(--line);
      background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
      color: white;
      position: sticky;
      top: 0;
      z-index: 2;
    }
    .seq-header h2 {
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .seq-header p,
    .seq-header-sub {
      margin-top: 6px;
      font-size: 0.78rem;
      opacity: 0.88;
      max-width: 52rem;
      line-height: 1.45;
    }
    .seq-close {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      border: 2px solid rgba(255,255,255,0.35);
      border-radius: 8px;
      background: rgba(255,255,255,0.1);
      color: white;
      font-size: 1.25rem;
      line-height: 1;
      cursor: pointer;
    }
    .seq-close:hover { background: rgba(255,255,255,0.2); }
    .seq-body { padding: 20px 24px 28px; }

    .seq-section { margin-bottom: 22px; }
    .seq-section-title {
      font-size: 0.62rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin-bottom: 10px;
    }

    /* Five lanes band */
    .seq-lanes {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 6px;
    }
    .seq-lane {
      border-radius: var(--radius-md);
      border: 1.5px solid var(--line);
      padding: 10px 10px 12px;
      text-align: center;
      font-size: 0.62rem;
      font-weight: 700;
      line-height: 1.3;
      box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08);
    }
    .seq-lane__name {
      display: block;
      font-size: 0.64rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .seq-lane .seq-lane-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.4rem;
      height: 1.4rem;
      border-radius: 50%;
      background: rgba(255,255,255,0.85);
      border: 2px solid currentColor;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.75rem;
      margin-bottom: 6px;
    }
    .seq-lane .seq-lane-phases {
      display: block;
      margin-top: 4px;
      font-size: 0.52rem;
      font-weight: 600;
      opacity: 0.85;
    }
    .seq-lane--discover { background: var(--discover-head); color: #78350f; }
    .seq-lane--plan { background: var(--plan-head); color: #1e3a8a; }
    .seq-lane--model { background: var(--model-head); color: #312e81; }
    .seq-lane--deploy { background: var(--deploy-head); color: #9a3412; }
    .seq-lane--operate { background: var(--operate-head); color: #065f46; }

    /* Phase spine */
    .seq-spine-wrap { overflow-x: auto; padding-bottom: 4px; }
    .seq-spine {
      display: flex;
      align-items: center;
      gap: 0;
      min-width: max-content;
    }
    .seq-phase {
      display: flex;
      flex-direction: column;
      align-items: center;
      min-width: 4.5rem;
      cursor: pointer;
      transition: transform 0.15s;
      border: none;
      background: transparent;
      padding: 0;
      font: inherit;
      color: inherit;
    }
    .seq-phase:hover { transform: translateY(-2px); }
    .seq-phase-node {
      width: 2rem;
      height: 2rem;
      border-radius: 8px;
      border: 2px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: "JetBrains Mono", monospace;
      font-size: 0.72rem;
      font-weight: 800;
      background: white;
    }
    .seq-phase-label {
      margin-top: 4px;
      font-size: 0.48rem;
      font-weight: 600;
      text-align: center;
      max-width: 4.2rem;
      line-height: 1.2;
      color: var(--muted);
    }
    .seq-arrow {
      color: #94a3b8;
      font-size: 0.85rem;
      font-weight: 700;
      padding: 0 2px;
      flex-shrink: 0;
    }
    .seq-phase--intake .seq-phase-node { background: #e2e8f0; }
    .seq-phase--poc .seq-phase-node { background: #fef08a; }
    .seq-phase--proto .seq-phase-node { background: #fed7aa; }
    .seq-phase--pilot .seq-phase-node { background: #93c5fd; }
    .seq-phase--prd .seq-phase-node { background: #86efac; }
    .seq-phase--prod .seq-phase-node { background: #6ee7b7; }
    .seq-phase--op .seq-phase-node { background: #a5b4fc; }
    .seq-phase--ret .seq-phase-node { background: #cbd5e1; }

    /* FTI + deploy pipelines */
    .seq-pipelines {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }
    .seq-pipe {
      border: 2px solid var(--box-line);
      border-radius: 10px;
      padding: 10px 12px;
      background: #f8fafc;
      font-size: 0.58rem;
    }
    .seq-pipe strong {
      display: block;
      font-size: 0.55rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 4px;
    }
    .seq-pipe--f { border-left: 4px solid #059669; }
    .seq-pipe--t { border-left: 4px solid #2563eb; }
    .seq-pipe--i { border-left: 4px solid #7c3aed; }
    .seq-pipe--d { border-left: 4px solid #ea580c; }

    /* Governance thread */
    .seq-gov-thread {
      display: flex;
      align-items: stretch;
      gap: 0;
      border: 2px solid #8b5cf6;
      border-radius: 10px;
      overflow: hidden;
      font-size: 0.58rem;
      font-weight: 600;
    }
    .seq-gov-seg {
      flex: 1;
      padding: 10px 12px;
      text-align: center;
      border-right: 1px solid rgba(139, 92, 246, 0.35);
    }
    .seq-gov-seg:last-child { border-right: none; }
    .seq-gov-seg--dst { background: var(--steward); color: #0369a1; }
    .seq-gov-seg--gc { background: var(--gov); color: var(--gov-h); }
    .seq-gov-seg--daigo { background: #fce7f3; color: #9d174d; }

    /* Loops + gap */
    .seq-loops {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .seq-loop-box {
      border: 1.5px dashed var(--box-line);
      border-radius: 10px;
      padding: 12px 14px;
      font-size: 0.58rem;
      background: #fafafa;
    }
    .seq-loop-box strong {
      display: block;
      font-size: 0.52rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .seq-loop-item {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 4px;
    }
    .seq-loop-arrow { color: #64748b; font-weight: 700; }

    .seq-gap-bar {
      margin-top: 8px;
      padding: 10px 14px;
      border-radius: 10px;
      background: var(--gap);
      border: 2px dashed var(--gap-h);
      font-size: 0.6rem;
      color: #991b1b;
      font-weight: 600;
      text-align: center;
    }

    .seq-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid #e2e8f0;
      font-size: 0.58rem;
      color: var(--muted);
    }
    .seq-legend__stage {
      padding: 5px 10px;
      border-radius: 8px;
      border: 1px solid rgba(15, 23, 42, 0.12);
      font-weight: 600;
    }
    .seq-legend__stage strong { font-weight: 800; }
    .seq-legend__stage--intake { background: #e2e8f0; color: #334155; }
    .seq-legend__stage--poc { background: #fef08a; color: #713f12; }
    .seq-legend__stage--proto { background: #fed7aa; color: #9a3412; }
    .seq-legend__stage--pilot { background: #93c5fd; color: #1e3a8a; }
    .seq-legend__stage--prd { background: #fcd34d; color: #78350f; }
    .seq-legend__stage--prod { background: #6ee7b7; color: #065f46; }
    .seq-legend__stage--op { background: #a5b4fc; color: #3730a3; }
    .seq-legend__stage--ret { background: #cbd5e1; color: #334155; }

    @media (max-width: 800px) {
      .seq-lanes { grid-template-columns: 1fr; }
      .seq-pipelines { grid-template-columns: 1fr 1fr; }
      .seq-loops { grid-template-columns: 1fr; }
      .seq-gov-thread { flex-direction: column; }
      .seq-gov-seg { border-right: none; border-bottom: 1px solid rgba(139, 92, 246, 0.35); }
    }

  .lifecycle-stages {
      background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
      padding: 0 10px 10px;
    }
