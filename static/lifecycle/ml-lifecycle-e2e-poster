  function loadDapsDraft() {
    try {
      const raw = localStorage.getItem(DAPS_DEFAULT_KEY);
      if (raw) {
        const parsed = JSON.parse(raw);
        return normalizeDapsDraft(parsed);
      }
    } catch (_) { /* ignore corrupt draft */ }
    return createEmptyDapsDraft();
  }

  function normalizeDapsDraft(data) {
    const base = createEmptyDapsDraft();
    if (!data || typeof data !== "object") return base;
    base.projectName = typeof data.projectName === "string" ? data.projectName : "";
    base.updatedAt = data.updatedAt || null;
    base.relationshipType = data.relationshipType || data.fields?.relationshipType || "";
    base.predictors = Array.isArray(data.predictors) && data.predictors.length
      ? data.predictors.map(String)
      : ["", "", ""];
    Object.keys(DAPS_FIELDS).forEach((key) => {
      if (DAPS_FIELDS[key].type === "predictors" || DAPS_FIELDS[key].type === "relationship") return;
      const val = data.fields?.[key] ?? data[key];
      base.fields[key] = typeof val === "string" ? val : "";
    });
    return base;
  }

