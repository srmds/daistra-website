  function isEditableTarget(t) {
    if (!t || !(t instanceof Element)) return false;
    const tag = t.tagName;
    if (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT") return true;
    if (t.isContentEditable) return true;
    return Boolean(t.closest("[contenteditable=true]"));
  }

  function shouldHandleLaneKeys(e) {
    if (e.defaultPrevented || e.altKey || e.ctrlKey || e.metaKey) return false;
    if (isEditableTarget(e.target)) return false;
    if (seqOverlay?.classList.contains("is-open")) return false;
    if (isOpen && e.target.closest(".detail-panel")) return false;
    return true;
